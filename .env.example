# Core (Owner: Backend Lead / DevOps)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
REDIS_URL=redis://USER:PASSWORD@HOST:6379
RATE_LIMIT_REDIS_PREFIX=rl:v1
RATE_LIMIT_REDIS_REQUIRED=true
JWT_SECRET=replace_with_secure_random
INTERNAL_API_SECRET=replace_with_secure_random
AUTH_TOKEN_SECRET=replace_with_secure_random

# API and App URLs (Owner: DevOps)
APP_URL=https://app.yourapp.com
API_URL=https://api.yourapp.com
NEXT_PUBLIC_API_URL=https://api.yourapp.com
SESSION_COOKIE_DOMAIN=.yourapp.com
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
INTERNAL_DEFAULT_TENANT_SLUG=demo
INTERNAL_DEFAULT_TENANT_ID=

# OpenAI (Owner: Backend Lead)
OPENAI_API_KEY=replace_with_openai_key
OPENAI_MODEL=gpt-5-mini
OPENAI_RESPONSES_ENABLED=true
SESSION_IDLE_RESET_MINUTES=45
OPENAI_MAX_CALLS_PER_SESSION=12
OPENAI_MAX_CALLS_PER_DAY_PER_TENANT=500
AI_FAILURE_HANDOFF_THRESHOLD=3
UNKNOWN_TURN_HANDOFF_THRESHOLD=3
BOT_AI_MAX_INPUT_CHARS=640
BOT_LATE_CANCEL_WARN_HOURS=24
BOT_LATE_CANCEL_BLOCK_HOURS=0

# Stripe (Owner: Backend Lead / Finance)
STRIPE_SECRET_KEY=replace_with_stripe_secret
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
STRIPE_API_VERSION=2025-09-30.clover
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace_with_stripe_publishable_key

# WhatsApp / Meta (Owner: Integrations Engineer)
WA_VERIFY_TOKEN=replace_with_wa_verify_token
WA_WEBHOOK_SECRET=replace_with_wa_webhook_secret
META_APP_SECRET=replace_with_meta_app_secret
WA_PHONE_NUMBER_ID=replace_with_wa_phone_number_id
WA_ACCESS_TOKEN=replace_with_wa_access_token
WA_ACCESS_TOKEN_BY_PHONE_JSON=
WA_ACTION_TOKEN_SECRET=replace_with_wa_action_token_secret
WA_TEMPLATE_REMINDER_24H=optional_whatsapp_template_name
WA_TEMPLATE_REMINDER_2H=optional_whatsapp_template_name
WA_TEMPLATE_ADMIN_BOOKING_CREATED=optional_whatsapp_template_name

# Telegram (Owner: Integrations Engineer)
TG_BOT_TOKEN=replace_with_tg_bot_token
TG_WEBHOOK_SECRET_TOKEN=replace_with_tg_webhook_secret
BOT_TENANT_SLUG=demo
BOT_TENANT_ID=
WA_ENTERPRISE_ROUTING_REQUIRED=false

# Email (Owner: Backend Lead)
EMAIL_API_KEY=replace_with_email_provider_key
EMAIL_FROM=no-reply@yourapp.com

# Monitoring (Owner: DevOps)
SENTRY_DSN=replace_with_sentry_dsn
OPS_ALERT_WEBHOOK_URL=
BOT_HEALTH_URL=
WORKER_HEALTH_URL=

# Worker (Owner: Backend Lead / DevOps)
WORKER_HEARTBEAT_MS=15000
WORKER_REMINDER_POLL_MS=60000
WORKER_REMINDER_24H_WINDOW_START_HOURS=23.5
WORKER_REMINDER_24H_WINDOW_END_HOURS=24.5
WORKER_REMINDER_2H_WINDOW_START_HOURS=1.5
WORKER_REMINDER_2H_WINDOW_END_HOURS=2.5
WORKER_DELIVERY_POLL_MS=30000
WORKER_DELIVERY_MAX_ATTEMPTS=5
WORKER_DELIVERY_BACKOFF_BASE_SECONDS=30
WORKER_CLEANUP_POLL_MS=600000
WORKER_NOTIFICATION_RETENTION_DAYS=90
WORKER_ADMIN_SECRET=replace_with_worker_admin_secret
