{
  "name": "genius_clients",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "start": "bash -lc \"${SERVICE_START_CMD:?SERVICE_START_CMD is required}\"",
    "build": "pnpm -r --filter \"./packages/*\" run build && pnpm -r --filter \"./apps/*\" run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "dev:web": "pnpm --filter @genius/web run dev",
    "dev:web-vite": "pnpm --filter @genius/web-vite run dev",
    "build:web-vite": "pnpm --filter @genius/web-vite run build",
    "build:web-vite:prerender": "pnpm --filter @genius/web-vite run build:prerender",
    "dev:api": "pnpm --filter @genius/api run dev",
    "dev:bot": "pnpm --filter @genius/bot run dev",
    "dev:worker": "pnpm --filter @genius/worker run dev",
    "i18n:check": "pnpm --filter @genius/i18n run check:parity",
    "test": "pnpm --filter @genius/i18n run test && pnpm --filter @genius/shared run test",
    "predeploy:env": "node scripts/validate-env.mjs all",
    "predeploy:quality": "node scripts/release/predeploy.mjs",
    "deploy:sync-branches": "bash scripts/release/sync-deploy-branches.sh",
    "deploy:sync-web-branch": "bash scripts/release/sync-service-branch.sh web deploy main",
    "staging:sync-branches": "bash scripts/release/sync-deploy-branches.sh staging",
    "deploy:wait-success": "bash scripts/release/wait-railway-success.sh",
    "deploy:sync-and-wait": "pnpm deploy:sync-branches && pnpm deploy:wait-success",
    "smoke:local": "node scripts/smoke/local-smoke.mjs",
    "smoke:production": "node scripts/smoke/production-smoke.mjs",
    "smoke:observability": "node scripts/smoke/bot-worker-observability-smoke.mjs",
    "smoke:stripe-webhook": "node scripts/smoke/stripe-webhook-idempotency.mjs",
    "smoke:bot:failover": "node scripts/smoke/bot-ai-failover-smoke.mjs",
    "smoke:alerts:webhook": "node scripts/smoke/ops-alert-webhook-smoke.mjs",
    "smoke:web-vite:prerender": "node scripts/smoke/web-vite-prerender-smoke.mjs",
    "smoke:web-vite:journey": "node scripts/smoke/web-vite-journey-smoke.mjs",
    "smoke:web-vite:api-target": "node scripts/smoke/web-vite-api-target-smoke.mjs",
    "smoke:tenant-host": "node scripts/smoke/tenant-host-resolution-smoke.mjs",
    "smoke:spa:auth-admin": "node scripts/smoke/spa-auth-admin-contract-smoke.mjs",
    "smoke:spa:public": "node scripts/smoke/spa-public-contract-smoke.mjs",
    "smoke:super-admin:flow": "node scripts/smoke/super-admin-flow-smoke.mjs",
    "smoke:super-admin:security": "node scripts/smoke/super-admin-security-smoke.mjs",
    "test:super-admin": "pnpm --filter @genius/api run test",
    "ops:cleanup-smoke-tenants": "bash scripts/ops/cleanup-smoke-tenants.sh",
    "release:spa:gates": "node scripts/release/spa-release-gates.mjs",
    "railway:audit-env": "bash scripts/release/audit-railway-env.sh production",
    "railway:audit-env:staging": "bash scripts/release/audit-railway-env.sh staging",
    "railway:audit-alerts": "bash scripts/release/audit-railway-alerts.sh",
    "predeploy": "pnpm predeploy:env && pnpm predeploy:quality"
  },
  "devDependencies": {
    "@types/node": "24.3.0",
    "typescript": "5.9.2"
  }
}
